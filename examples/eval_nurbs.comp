#version 450
#extension GL_GOOGLE_include_directive : enable

/*
 * eval_nurbs.comp — NURBS curve evaluation compute shader
 *
 * Evaluates a 3-D NURBS curve at a uniform set of parameter values and
 * writes the resulting XYZ points to an output buffer.
 *
 * Uses qaws_nurbs_eval_core.h and qaws_bspline_basis_core.h (same kernels
 * used by the qaws C runtime on the CPU).
 *
 * Buffer layout:
 *   Binding 0 (KnotBuffer)   : knot vector (float[])
 *   Binding 1 (CPBuffer)     : control points, flat xyz (float[])
 *   Binding 2 (WeightBuffer) : per-control-point weights (float[])
 *   Binding 3 (OutBuffer)    : output XYZ positions (float[])
 *
 * Push constants:
 *   degree       — NURBS degree
 *   num_cp       — number of control points
 *   sample_count — number of output points
 */

#include "../src/qaws/qaws_glsl.h"
#include "../src/qaws/core/qaws_bspline_basis_core.h"
#include "../src/qaws/core/qaws_nurbs_eval_core.h"

layout(std430, binding = 0) readonly buffer KnotBuffer   { float knots[];          };
layout(std430, binding = 1) readonly buffer CPBuffer     { float control_points[];  };
layout(std430, binding = 2) readonly buffer WeightBuffer { float weights[];         };
layout(std430, binding = 3) buffer         OutBuffer     { float results[];         };

layout(push_constant) uniform Params {
    uint degree;
    uint num_cp;
    uint sample_count;
};

layout(local_size_x = 256) in;

void main()
{
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= sample_count)
        return;

    /* Parameter t in the valid knot span [knots[degree], knots[num_cp]]. */
    float t_min = knots[degree];
    float t_max = knots[num_cp];
    float t = t_min + float(idx) / float(sample_count - 1u) * (t_max - t_min);

    /* Copy the relevant knot window and control points / weights into
     * local arrays (required by the GLSL core functions). */
    float local_knots  [QAWS_CORE_MAX_POINTS * 2];
    float local_cp     [QAWS_CORE_MAX_POINTS * 3];
    float local_weights[QAWS_CORE_MAX_POINTS];

    int span = qaws_find_span(knots, int(degree), int(num_cp), t);

    int j;
    int order = int(degree) + 1;

    for (j = 0; j < order * 2; j++)
        local_knots[j] = knots[span - int(degree) + j];

    for (j = 0; j <= int(degree); j++) {
        uint cp_idx = uint(span - int(degree) + j) * 3u;
        local_cp[j * 3 + 0] = control_points[cp_idx + 0u];
        local_cp[j * 3 + 1] = control_points[cp_idx + 1u];
        local_cp[j * 3 + 2] = control_points[cp_idx + 2u];
        local_weights[j] = weights[uint(span - int(degree) + j)];
    }

    /* Evaluate: QAWS_EVAL_FLAG_POSITION = 0x1 */
    qaws_eval_3d result = qaws_nurbs_eval_3d(
        local_cp, local_knots, local_weights,
        int(degree), int(degree), t, 1);

    results[idx * 3u + 0u] = result.position.x;
    results[idx * 3u + 1u] = result.position.y;
    results[idx * 3u + 2u] = result.position.z;
}
